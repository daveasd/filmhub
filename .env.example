# FilmHub — copy to .env for local dev. Never commit .env to git.
# On Vercel: Project → Settings → Environment Variables (same names).

# ─── TMDB (at least one required for real movie data) ───────────────────────
# https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# ─── Supabase (required for auth, cloud sync, AI edge function) ─────────────
# Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# ─── Server-only (NOT for frontend / Vercel) ────────────────────────────────
# Set in Supabase Dashboard → Edge Functions → Secrets:
#   GROQ_API_KEY=your_groq_key
# Optional: GROQ_MODEL=llama-3.3-70b-versatile
# Never add GROQ_API_KEY or SUPABASE_SERVICE_ROLE_KEY to Vite env vars.
